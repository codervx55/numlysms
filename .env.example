# --- Supabase ---
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role key — server-only, NEVER expose to the client. Used for the
# XeroSMS webhook and admin operations that must bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Database (Prisma, via Supabase connection pooler) ---
# Project Settings → Database → Connection string
# DATABASE_URL: pooled connection (port 6543), used at runtime
# DIRECT_URL: direct connection (port 5432), used only for migrations
DATABASE_URL=postgresql://postgres.xxxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

# --- XeroSMS ---
XEROSMS_API_KEY=your_xerosms_api_key
XEROSMS_BASE_URL=https://api.xerosms.com/v1

# --- Paystack ---
PAYSTACK_SECRET_KEY=sk_live_or_test_xxx
PAYSTACK_PUBLIC_KEY=pk_live_or_test_xxx

# --- Cron ---
# Shared secret for the expiry-sweep endpoint. Set the same value here (on Railway)
# and as a GitHub Actions repo secret (Settings → Secrets and variables → Actions).
CRON_SECRET=generate_a_long_random_string

